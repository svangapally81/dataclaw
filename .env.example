# DataClaw configuration. Copy to .env and edit.
#
# Replace the two secret placeholders below before starting the app.
# Placeholder values are rejected at startup by validate_runtime_secrets.
#
# Generate fresh values:
#
#   python3 -c "from cryptography.fernet import Fernet; print('MASTER_KEY=' + Fernet.generate_key().decode())"
#   python3 -c "import secrets; print('SESSION_SECRET=' + secrets.token_urlsafe(48))"
#
# Paste the output into the two lines below (or `dataclaw init` does this
# for you automatically at ~/.dataclaw/.env).

# Required: 32-byte Fernet key + session secret. Rotate per environment.
MASTER_KEY=replace-with-long-random-master-key
SESSION_SECRET=replace-with-long-random-session-secret

# Seeded admin user — used for the initial sign-in.
ADMIN_EMAIL=admin@dataclaw.local
ADMIN_PASSWORD=dataclaw-local-admin

# SQLite is the app database. Use Postgres only as a data source connector.
DATABASE_URL=sqlite+aiosqlite:///data/dataclaw.sqlite
DEMO_DATABASE_URL=sqlite+aiosqlite:///data/dataclaw_demo.sqlite

# ChromaDB is required. `make dev` starts it locally on port 8001.
CHROMA_URL=http://localhost:8001
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
DATACLAW_LLM_PROVIDER=openai
WIKI_ROOT=data/wiki
DATACLAW_AUTH_DISABLED=false
SECURE_COOKIES=false

# CORS — comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional bootstrap only. `dataclaw bootstrap-admin` can seed the OpenAI provider
# from this value; runtime chat/agents read only the UI-configured provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Demo/screenshot mode: Observability returns six curated mock events without DB reads.
OBSERVABILITY_MOCK=false

# Optional alert delivery. Per-agent monitoring config chooses recipients/routing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true
PAGERDUTY_ROUTING_KEY=

# Demo mode seeds local demo content. Schema migrations run through `dataclaw init`
# or `dataclaw migrate`; API startup does not create tables.
DEMO_MODE=true
