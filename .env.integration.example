# Enable local Docker connector integration tests.
RUN_CONNECTOR_INTEGRATION=1

# Enable SaaS connector integration tests. Missing credentials skip cleanly.
RUN_SAAS_CONNECTOR_INTEGRATION=0

# Notion
NOTION_INTEGRATION_TOKEN=
NOTION_DATABASE_IDS=

# Google Docs / Drive
GOOGLE_DOCS_SERVICE_ACCOUNT_JSON=

# Quip
QUIP_ACCESS_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_REPOSITORIES=owner/repo

# Confluence
CONFLUENCE_SITE_URL=https://example.atlassian.net
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Redshift
REDSHIFT_CLUSTER_ENDPOINT=
REDSHIFT_DATABASE=
REDSHIFT_USER=
REDSHIFT_PASSWORD=

# Databricks
DATABRICKS_WORKSPACE_URL=https://example.cloud.databricks.com
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# BigQuery
BIGQUERY_SERVICE_ACCOUNT_JSON=
BIGQUERY_PROJECT_ID=

# dbt Cloud
DBT_API_TOKEN=
DBT_ACCOUNT_ID=

# Fivetran
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
